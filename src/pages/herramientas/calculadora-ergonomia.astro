---
import Base from '@/layouts/Base.astro';

const siteUrl = 'https://tuespaciodetrabajo.com';
const pageUrl = `${siteUrl}/herramientas/calculadora-ergonomia/`;
const pageTitle = 'Calculadora de ergonomía: altura silla y escritorio';
const pageDescription = 'Calcula la altura exacta que necesitan tu silla, escritorio y monitor según tu estatura. Gratis, sin registro, con figura interactiva.';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Herramientas', item: `${siteUrl}/herramientas/` },
    { '@type': 'ListItem', position: 3, name: 'Calculadora de ergonomía', item: pageUrl },
  ],
};

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Calculadora de ergonomía — Tu Espacio de Trabajo',
  url: pageUrl,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Web',
  description: pageDescription,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
  author: { '@type': 'Person', name: 'David Rubio', url: `${siteUrl}/sobre-mi/` },
  inLanguage: 'es',
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Cómo calcular la altura correcta de tu escritorio, silla y monitor',
  description: 'Guía paso a paso para calcular las medidas ergonómicas ideales de tu puesto de trabajo según tu estatura.',
  totalTime: 'PT3M',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Introduce tus datos', text: 'Indica tu estatura, género y rango de edad en el primer paso.' },
    { '@type': 'HowToStep', position: 2, name: 'Describe tu setup', text: 'Di qué monitor usas, qué tipo de silla tienes y cuántas horas al día pasas sentado.' },
    { '@type': 'HowToStep', position: 3, name: 'Marca tus dolencias', text: 'Selecciona las zonas donde notas molestias para recibir recomendaciones personalizadas.' },
    { '@type': 'HowToStep', position: 4, name: 'Aplica las medidas', text: 'Ajusta silla, escritorio y monitor a las alturas calculadas y prioriza las compras que más impacten tu caso.' },
  ],
};

const faqs = [
  {
    pregunta: '¿De dónde salen las fórmulas de la calculadora?',
    respuesta: 'Están basadas en datos antropométricos estándar de la norma ISO 7250 y la base de datos DINED (TU Delft), validadas por Cornell University Ergonomics Lab y Humanscale. Los coeficientes (asiento = estatura × 0,253, escritorio = estatura × 0,384, borde superior del monitor = estatura × 0,703) son los percentiles P50 para población europea adulta. La calculadora ajusta por género, rango de edad y escenarios específicos (embarazo, obesidad) siguiendo las directrices de la Human Factors and Ergonomics Society.',
  },
  {
    pregunta: '¿Por qué me piden el género y la edad?',
    respuesta: 'Porque la proporción pierna/torso varía entre hombres y mujeres (las mujeres tienen en promedio el tronco 2-4 cm más corto proporcionalmente, lo que cambia la altura de asiento ideal). Y a partir de los 60 años la rigidez lumbar hace recomendable un respaldo más abierto (100-105° en lugar de 95°) y un monitor ligeramente más alto por la presbicia. Son ajustes pequeños pero que marcan diferencia si vas a trabajar 8 horas al día.',
  },
  {
    pregunta: '¿Qué es el score ergonómico de mi setup actual?',
    respuesta: 'Un número entre 0 y 100 que estima qué tan ergonómico es tu puesto de trabajo actual, basado en los datos que introduces (tipo de silla, monitor, horas de uso, dolores reportados). Por encima de 70 el setup es razonable; entre 40 y 70 tiene problemas importantes; por debajo de 40 es muy probable que te esté generando dolor acumulado. No sustituye a una valoración médica, pero te dice por dónde empezar.',
  },
  {
    pregunta: '¿Es obligatorio que mi escritorio sea elevable para estar bien sentado?',
    respuesta: 'No. Si tu escritorio fijo tiene una altura razonable (72-75 cm), puedes compensar con la silla y un reposapiés. Un escritorio elevable eléctrico solo merece la pena si mides menos de 162 cm o más de 185 cm, o si quieres alternar sentado y de pie durante la jornada. Para estaturas fuera del rango común, es casi la única solución cómoda.',
  },
  {
    pregunta: '¿Por qué la distancia al monitor depende de las pulgadas?',
    respuesta: 'Cuanto más grande el monitor, más lejos lo necesitas para ver toda la pantalla sin mover la cabeza. Un 24" funciona bien entre 60 y 75 cm; un 32" pide 80-95 cm. Si lo pones demasiado cerca, fuerzas los ojos y los músculos extraoculares. Demasiado lejos pierdes detalle y te inclinas hacia delante sin darte cuenta.',
  },
  {
    pregunta: '¿Puedo compartir mi resultado con alguien?',
    respuesta: 'Sí. Cuando llegues a la pantalla de resultados verás un botón de "Compartir" que copia al portapapeles un enlace con tus datos precargados. Si se lo pasas a tu pareja, a un compañero o te lo guardas en Notas, al abrir ese enlace ves directamente el mismo resultado sin tener que volver a rellenar nada.',
  },
  {
    pregunta: '¿Sirve la calculadora si uso un portátil sin monitor externo?',
    respuesta: 'Sí, pero con matices importantes. Si trabajas solo con portátil, la pantalla queda siempre demasiado baja o el teclado demasiado alto — uno de los dos, no puedes evitarlo. La recomendación real es usar un soporte para el portátil que lo eleve a la altura de los ojos y añadir un teclado y un ratón externos. La calculadora te dará la medida correcta para el teclado externo y marcará la prioridad de comprar un soporte.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.pregunta,
    acceptedAnswer: { '@type': 'Answer', text: f.respuesta },
  })),
};
---

<Base title={pageTitle} description={pageDescription} canonical={pageUrl} image="/images/og/calculadora-ergonomia.jpg">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(softwareAppSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <div class="container ergo-page">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <a href="/herramientas/">Herramientas</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>Calculadora de ergonomía</span>
    </nav>

    <header class="ergo-header">
      <span class="ergo-eyebrow">Herramienta · ISO 7250 · Gratis</span>
      <h1>Calculadora de ergonomía</h1>
      <p class="ergo-lead">
        En 3 pasos te digo a qué altura exacta tienen que quedar silla, escritorio y monitor según
        tu cuerpo y cómo trabajas. Con figura técnica, score de tu setup actual y recomendaciones
        priorizadas según dónde te duele.
      </p>
    </header>

    <section id="ergo-app" class="ergo-app" data-step="1" aria-label="Calculadora de ergonomía interactiva">
      <!-- Progress -->
      <div class="ergo-progress-wrapper">
        <div
          class="ergo-progress"
          role="progressbar"
          aria-valuemin="0"
          aria-valuemax="3"
          aria-valuenow="0"
          aria-valuetext="Paso 1 de 3: tus datos"
          id="ergo-progress"
        >
          <div class="ergo-progress-bar"></div>
        </div>
        <ol class="ergo-progress-steps" aria-hidden="true">
          <li data-step="1" class="is-active"><span class="ergo-step-dot">1</span><span class="ergo-step-label">Tú</span></li>
          <li data-step="2"><span class="ergo-step-dot">2</span><span class="ergo-step-label">Setup</span></li>
          <li data-step="3"><span class="ergo-step-dot">3</span><span class="ergo-step-label">Dolor</span></li>
          <li data-step="4"><span class="ergo-step-dot">✓</span><span class="ergo-step-label">Resultado</span></li>
        </ol>
      </div>

      <div class="ergo-stage">
        <!-- Panel input izquierda -->
        <div class="ergo-panel-input">
          <!-- STEP 1: Tus datos -->
          <section class="ergo-step is-active" data-panel="1" aria-labelledby="step-1-title">
            <h2 id="step-1-title" class="ergo-step-title">Cuéntame sobre ti</h2>
            <p class="ergo-step-sub">Con la estatura basta. El género y la edad afinan el resultado.</p>

            <div class="ergo-field">
              <div class="ergo-field-head">
                <label for="inp-estatura">Tu estatura</label>
                <output class="ergo-field-value" id="out-estatura" for="inp-estatura"><span id="out-estatura-val">175</span><span class="ergo-unit"> cm</span></output>
              </div>
              <input
                type="range"
                id="inp-estatura"
                name="estatura"
                min="140"
                max="210"
                step="1"
                value="175"
                aria-describedby="estatura-hint"
              />
              <div class="ergo-slider-ticks" aria-hidden="true">
                <span>140</span><span>160</span><span>175</span><span>190</span><span>210</span>
              </div>
              <input type="number" id="inp-estatura-num" min="140" max="210" step="1" value="175" class="ergo-field-num" aria-label="Estatura en centímetros (numérico)" />
              <span class="ergo-field-hint" id="estatura-hint">Arrastra el slider o escribe el número.</span>
            </div>

            <fieldset class="ergo-field">
              <legend>Género</legend>
              <div class="ergo-radio-grid">
                <label class="ergo-chip">
                  <input type="radio" name="genero" value="h" checked />
                  <span>Hombre</span>
                </label>
                <label class="ergo-chip">
                  <input type="radio" name="genero" value="m" />
                  <span>Mujer</span>
                </label>
                <label class="ergo-chip">
                  <input type="radio" name="genero" value="x" />
                  <span>Prefiero no decir</span>
                </label>
              </div>
              <span class="ergo-field-hint">La proporción pierna/torso varía entre hombres y mujeres. Ajusta la altura del asiento.</span>
            </fieldset>

            <fieldset class="ergo-field">
              <legend>Rango de edad</legend>
              <div class="ergo-radio-grid">
                <label class="ergo-chip">
                  <input type="radio" name="edad" value="<30" />
                  <span>Menos de 30</span>
                </label>
                <label class="ergo-chip">
                  <input type="radio" name="edad" value="30-45" checked />
                  <span>30-45</span>
                </label>
                <label class="ergo-chip">
                  <input type="radio" name="edad" value="45-60" />
                  <span>45-60</span>
                </label>
                <label class="ergo-chip">
                  <input type="radio" name="edad" value=">60" />
                  <span>Más de 60</span>
                </label>
              </div>
            </fieldset>
          </section>

          <!-- STEP 2: Tu setup -->
          <section class="ergo-step" data-panel="2" aria-labelledby="step-2-title" hidden>
            <h2 id="step-2-title" class="ergo-step-title">Tu setup actual</h2>
            <p class="ergo-step-sub">Para calcular tu score y priorizar qué cambiar primero.</p>

            <fieldset class="ergo-field">
              <legend>Monitor principal</legend>
              <div class="ergo-radio-grid ergo-radio-grid--compact">
                <label class="ergo-chip"><input type="radio" name="monitor" value="22" /><span>22"</span></label>
                <label class="ergo-chip"><input type="radio" name="monitor" value="24" checked /><span>24"</span></label>
                <label class="ergo-chip"><input type="radio" name="monitor" value="27" /><span>27"</span></label>
                <label class="ergo-chip"><input type="radio" name="monitor" value="32" /><span>32"</span></label>
                <label class="ergo-chip"><input type="radio" name="monitor" value="34" /><span>34" ultra</span></label>
                <label class="ergo-chip"><input type="radio" name="monitor" value="laptop" /><span>Solo portátil</span></label>
              </div>
            </fieldset>

            <fieldset class="ergo-field">
              <legend>¿Qué silla usas?</legend>
              <div class="ergo-radio-grid">
                <label class="ergo-chip"><input type="radio" name="silla" value="ergo" checked /><span>Ergonómica (soporte lumbar regulable)</span></label>
                <label class="ergo-chip"><input type="radio" name="silla" value="gaming" /><span>Gaming</span></label>
                <label class="ergo-chip"><input type="radio" name="silla" value="basica" /><span>Básica de oficina</span></label>
                <label class="ergo-chip"><input type="radio" name="silla" value="ninguna" /><span>Silla de comedor o similar</span></label>
              </div>
            </fieldset>

            <div class="ergo-field">
              <div class="ergo-field-head">
                <label for="inp-horas">Horas al día sentado</label>
                <output class="ergo-field-value" id="out-horas" for="inp-horas"><span id="out-horas-val">8</span><span class="ergo-unit"> h</span></output>
              </div>
              <input type="range" id="inp-horas" name="horas" min="1" max="14" step="1" value="8" />
              <div class="ergo-slider-ticks" aria-hidden="true">
                <span>1</span><span>4</span><span>8</span><span>12</span><span>14</span>
              </div>
            </div>

            <fieldset class="ergo-field">
              <legend>¿Trabajas también de pie?</legend>
              <div class="ergo-radio-grid">
                <label class="ergo-chip"><input type="radio" name="usoPie" value="sentado" checked /><span>Siempre sentado</span></label>
                <label class="ergo-chip"><input type="radio" name="usoPie" value="alternar" /><span>Alterno</span></label>
                <label class="ergo-chip"><input type="radio" name="usoPie" value="pie" /><span>Casi siempre de pie</span></label>
              </div>
            </fieldset>
          </section>

          <!-- STEP 3: Dolor -->
          <section class="ergo-step" data-panel="3" aria-labelledby="step-3-title" hidden>
            <h2 id="step-3-title" class="ergo-step-title">¿Dónde notas molestias?</h2>
            <p class="ergo-step-sub">Marca todas las que apliquen. Ajusto las recomendaciones según lo que te duela.</p>

            <fieldset class="ergo-field">
              <legend class="sr-only">Zonas con dolor</legend>
              <div class="ergo-dolor-grid">
                <label class="ergo-dolor-chip" data-dolor="lumbar">
                  <input type="checkbox" name="dolor" value="lumbar" />
                  <svg class="ergo-dolor-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v18"/><path d="M7 8c0-3 2-5 5-5s5 2 5 5"/><path d="M7 16c0 3 2 5 5 5s5-2 5-5"/></svg>
                  <span class="ergo-dolor-label">Lumbar</span>
                  <span class="ergo-dolor-desc">Espalda baja</span>
                </label>
                <label class="ergo-dolor-chip" data-dolor="cervical">
                  <input type="checkbox" name="dolor" value="cervical" />
                  <svg class="ergo-dolor-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="5" r="3"/><path d="M9 8v5a3 3 0 0 0 3 3h0a3 3 0 0 0 3-3V8"/></svg>
                  <span class="ergo-dolor-label">Cervical</span>
                  <span class="ergo-dolor-desc">Cuello y trapecios</span>
                </label>
                <label class="ergo-dolor-chip" data-dolor="hombros">
                  <input type="checkbox" name="dolor" value="hombros" />
                  <svg class="ergo-dolor-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 0 1 18 0"/><path d="M6 12v5"/><path d="M18 12v5"/></svg>
                  <span class="ergo-dolor-label">Hombros</span>
                  <span class="ergo-dolor-desc">Tensión dorsal</span>
                </label>
                <label class="ergo-dolor-chip" data-dolor="muñecas">
                  <input type="checkbox" name="dolor" value="muñecas" />
                  <svg class="ergo-dolor-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3v7"/><path d="M16 3v7"/><path d="M7 10h10l-1 8a3 3 0 0 1-3 3h-2a3 3 0 0 1-3-3z"/></svg>
                  <span class="ergo-dolor-label">Muñecas</span>
                  <span class="ergo-dolor-desc">Túnel carpiano, tendinitis</span>
                </label>
                <label class="ergo-dolor-chip" data-dolor="ojos">
                  <input type="checkbox" name="dolor" value="ojos" />
                  <svg class="ergo-dolor-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
                  <span class="ergo-dolor-label">Ojos</span>
                  <span class="ergo-dolor-desc">Fatiga visual</span>
                </label>
                <label class="ergo-dolor-chip ergo-dolor-chip--none" data-dolor="ninguno">
                  <input type="checkbox" name="dolor" value="ninguno" />
                  <svg class="ergo-dolor-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                  <span class="ergo-dolor-label">Ninguno</span>
                  <span class="ergo-dolor-desc">Estoy bien</span>
                </label>
              </div>
              <span class="ergo-field-hint">Opcional. Si marcas dolores, las recomendaciones se priorizan.</span>
            </fieldset>
          </section>

          <!-- STEP 4: Results -->
          <section class="ergo-step ergo-step--results" data-panel="4" aria-labelledby="step-4-title" hidden>
            <div class="ergo-results-head">
              <h2 id="step-4-title" class="ergo-step-title">Tu puesto ideal</h2>
              <button type="button" class="ergo-share-btn" id="btn-share" aria-label="Compartir resultado">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.59 13.51l6.83 3.98"/><path d="M15.41 6.51l-6.82 3.98"/></svg>
                <span>Compartir</span>
              </button>
            </div>

            <!-- Score -->
            <div class="ergo-score-panel">
              <div class="ergo-score-gauge" aria-hidden="true">
                <svg viewBox="0 0 120 70" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <linearGradient id="gauge-grad" x1="0" y1="0" x2="100%" y2="0">
                      <stop offset="0%" stop-color="#ef4444"/>
                      <stop offset="45%" stop-color="#f59e0b"/>
                      <stop offset="100%" stop-color="#10b981"/>
                    </linearGradient>
                  </defs>
                  <path d="M 10 60 A 50 50 0 0 1 110 60" stroke="currentColor" stroke-width="8" stroke-linecap="round" fill="none" opacity="0.12"/>
                  <path d="M 10 60 A 50 50 0 0 1 110 60" stroke="url(#gauge-grad)" stroke-width="8" stroke-linecap="round" fill="none" id="gauge-fill" stroke-dasharray="157" stroke-dashoffset="157"/>
                </svg>
                <div class="ergo-score-num" id="score-num">—</div>
                <div class="ergo-score-label">de 100</div>
              </div>
              <div class="ergo-score-text">
                <div class="ergo-score-tag" id="score-tag">Calculando…</div>
                <p class="ergo-score-sub" id="score-desc">Score de tu setup actual según tus respuestas.</p>
              </div>
            </div>

            <!-- Resumen calculado -->
            <p class="ergo-results-sub" id="result-sub"></p>

            <!-- Measures -->
            <div class="ergo-measures" id="result-measures"></div>

            <!-- Tips -->
            <div class="ergo-tips" id="result-tips"></div>

            <!-- CTAs -->
            <div class="ergo-ctas-block" id="result-ctas-block">
              <h3 class="ergo-ctas-title">Tu hoja de ruta</h3>
              <p class="ergo-ctas-intro" id="ctas-intro">Ordenado por lo que más impacto tendrá en tu caso.</p>
              <ol class="ergo-ctas-list" id="result-ctas"></ol>
            </div>
          </section>
        </div>

        <!-- Panel figura derecha -->
        <aside class="ergo-panel-figure" aria-labelledby="fig-head-label">
          <div class="ergo-figure-head">
            <span class="ergo-figure-label" id="fig-head-label">Vista lateral · escala 1:X</span>
            <span class="ergo-figure-dims" id="fig-dims">175 cm · 24"</span>
          </div>
          <div class="ergo-figure-canvas" id="svg-stage" aria-hidden="true"></div>
          <p class="sr-only" id="fig-alt">Figura técnica con persona sentada, escritorio, silla y monitor. Altura asiento 44 cm, altura escritorio 67 cm, borde superior monitor 123 cm del suelo.</p>
          <div class="ergo-figure-legend" aria-hidden="true">
            <span class="ergo-legend-item"><span class="ergo-legend-dot" style="background:var(--color-accent)"></span>Silla</span>
            <span class="ergo-legend-item"><span class="ergo-legend-dot" style="background:var(--color-primary)"></span>Escritorio</span>
            <span class="ergo-legend-item"><span class="ergo-legend-dot" style="background:#10b981"></span>Zona segura</span>
          </div>
        </aside>
      </div>

      <!-- Controls -->
      <div class="ergo-controls">
        <button type="button" class="ergo-btn ergo-btn-secondary" id="btn-back" hidden>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          <span>Atrás</span>
        </button>
        <button type="button" class="ergo-btn ergo-btn-primary" id="btn-next">
          <span id="btn-next-label">Siguiente</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </div>

      <!-- Live region -->
      <div class="sr-only" role="status" aria-live="polite" aria-atomic="true" id="live-region"></div>

      <!-- Share modal -->
