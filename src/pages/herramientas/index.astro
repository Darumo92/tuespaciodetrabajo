---
import Base from '@/layouts/Base.astro';

const siteUrl = 'https://tuespaciodetrabajo.com';
const pageUrl = `${siteUrl}/herramientas/`;

const herramientas = [
  {
    titulo: 'Calculadora de ergonomía',
    descripcion: 'Calcula la altura exacta de silla, escritorio y monitor según tu estatura. Con figura interactiva y recomendaciones personalizadas.',
    href: '/herramientas/calculadora-ergonomia/',
    etiqueta: 'Gratis',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Herramientas', item: pageUrl },
  ],
};
---

<Base
  title="Herramientas gratis para optimizar tu home office — Tu Espacio de Trabajo"
  description="Calculadoras y utilidades gratis para montar tu home office: calcula alturas ergonómicas, compara productos y más."
  canonical={pageUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <article class="container tool-page">
    <nav class="breadcrumb" aria-label="Migas de pan">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span>Herramientas</span>
    </nav>

    <header class="tool-header">
      <h1>Herramientas para tu home office</h1>
      <p class="lead">
        Utilidades gratuitas para ayudarte a tomar decisiones sobre tu espacio de trabajo.
        Sin registro, sin spam, sin trampa.
      </p>
    </header>

    <section class="related-links" style="margin-top:2rem">
      <ul class="related-links">
        {herramientas.map((h) => (
          <li>
            <a href={h.href}>
              <strong>{h.titulo}</strong>
              <span style="display:block;font-size:0.9rem;color:var(--color-text-muted);margin-top:0.25rem;font-weight:400">{h.descripcion}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </article>
</Base>
