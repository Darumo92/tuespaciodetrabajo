---
import Base from '@/layouts/Base.astro';
---

<Base title="Pagina no encontrada | Tu Espacio de Trabajo" description="La pagina que buscas no existe o ha sido movida.">
  <meta name="robots" content="noindex" slot="head" />
  <div class="container text-center" style="padding: 6rem 1rem;">
    <p style="font-size: 5rem; margin-bottom: 1rem;">🖥️</p>
    <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.75rem;">
      Pagina no encontrada
    </h1>
    <p style="color: var(--color-text-muted); margin-bottom: 2rem; max-width: 420px; margin-left: auto; margin-right: auto;">
      Parece que esta pagina se ha perdido entre cables. Prueba a volver al inicio o usa el buscador.
    </p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/" class="affiliate-button" style="font-size: 1rem; padding: 0.75rem 1.75rem;">
        Volver al inicio
      </a>
      <a href="/buscar/" class="affiliate-button" style="font-size: 1rem; padding: 0.75rem 1.75rem; background: var(--color-secondary);">
        Buscar articulos
      </a>
    </div>
  </div>
</Base>
