---
import Base from '@/layouts/Base.astro';
---

<Base title="Página no encontrada | Tu Espacio de Trabajo" description="La página que buscas no existe o ha sido movida.">
  <meta name="robots" content="noindex" slot="head" />
  <div class="container text-center page-404">
    <div class="page-404-number">404</div>
    <h1 class="page-404-title">
      Página no encontrada
    </h1>
    <p class="page-404-desc">
      Parece que esta página se ha perdido entre cables. Prueba a volver al inicio o usa el buscador.
    </p>
    <div class="page-404-actions">
      <a href="/" class="hero-cta-btn hero-cta-primary">
        Volver al inicio
      </a>
      <a href="/buscar/" class="hero-cta-btn hero-cta-secondary">
        Buscar artículos
      </a>
    </div>
  </div>
</Base>

<style>
  .page-404 {
    padding: 8rem 1rem 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .page-404-number {
    font-family: var(--font-display);
    font-size: clamp(6rem, 20vw, 10rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 50%, var(--color-rose) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .page-404-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0;
  }

  .page-404-desc {
    color: var(--color-text-muted);
    max-width: 420px;
    line-height: 1.65;
    font-size: 1.05rem;
    margin: 0;
  }

  .page-404-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
</style>
