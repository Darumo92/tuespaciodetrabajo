---
import Base from '@/layouts/Base.astro';
import CategoryIcon from '@/components/CategoryIcon.astro';

const siteUrl = 'https://tuespaciodetrabajo.com';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Buscar', item: `${siteUrl}/buscar/` },
  ],
};
---

<Base
  title="Buscador de artículos | Tu Espacio de Trabajo"
  description="Busca entre todas nuestras guías y comparativas de productos de home office. Encuentra análisis de sillas, escritorios, accesorios y más."
  canonical="https://tuespaciodetrabajo.com/buscar/"
  noindex={true}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <div class="container section">
    <h1 class="search-title">
      Buscar artículos
    </h1>
    <p class="search-subtitle">
      Encuentra guías y comparativas sobre productos para tu home office
    </p>

    <div class="search-box">
      <label for="search-input" class="sr-only">Buscar artículos</label>
      <div class="search-input-wrap">
        <span class="search-icon" aria-hidden="true">🔍</span>
        <input
          type="search"
          id="search-input"
          placeholder="¿Qué estás buscando? Ej: silla ergonómica, standing desk..."
          autocomplete="off"
          spellcheck="false"
        />
      </div>
      <div id="search-meta" class="search-meta search-meta--hidden"></div>
    </div>

    <div id="results-container">
      <div id="loading-state" class="search-state">
        <p class="text-muted">Cargando índice de artículos...</p>
      </div>
      <div id="empty-state" class="search-state search-state--hidden">
        <p class="search-state-icon">🖥️</p>
        <p class="text-muted">Escribe algo para buscar entre los artículos</p>
      </div>
      <div id="no-results-state" class="search-state search-state--hidden">
        <p class="search-state-icon">🔍</p>
        <h2 class="search-state-heading">Sin resultados</h2>
        <p class="text-muted">Prueba con otras palabras clave o explora por categoria:</p>
        <div class="search-state-cats">
          <a href="/sillas/" class="affiliate-button search-cat-btn"><CategoryIcon categoria="sillas" size={14} /> Sillas</a>
          <a href="/escritorios/" class="affiliate-button search-cat-btn"><CategoryIcon categoria="escritorios" size={14} /> Escritorios</a>
          <a href="/accesorios/" class="affiliate-button search-cat-btn"><CategoryIcon categoria="accesorios" size={14} /> Accesorios</a>
          <a href="/ambiente/" class="affiliate-button search-cat-btn"><CategoryIcon categoria="ambiente" size={14} /> Ambiente</a>
          <a href="/audio-video/" class="affiliate-button search-cat-btn"><CategoryIcon categoria="audio-video" size={14} /> Audio y Video</a>
        </div>
      </div>
      <div id="results-grid" class="articles-grid search-results--hidden" role="region" aria-live="polite" aria-label="Resultados de busqueda"></div>
    </div>
  </div>
</Base>

<style>
  .search-box {
    margin-bottom: 2.5rem;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.1rem;
    pointer-events: none;
  }

  #search-input {
    width: 100%;
    padding: 0.85rem 1.25rem 0.85rem 3rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    outline: none;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  #search-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  #search-input::placeholder {
    color: var(--color-text-light);
  }

  .search-meta {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .search-state {
    text-align: center;
    padding: 4rem 1rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .search-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .search-subtitle {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .search-input-wrap {
    position: relative;
  }

  .search-meta--hidden {
    display: none;
  }

  .search-state--hidden {
    display: none;
  }

  .search-results--hidden {
    display: none;
  }

  .search-state-icon {
    font-size: 3rem;
    margin-bottom: 0.75rem;
  }

  .search-state-heading {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .search-state-cats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 1rem;
  }

  .search-cat-btn {
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
  }

  .search-error {
    color: var(--color-primary);
  }
</style>

<script>
  const CATEGORIA_NOMBRES: Record<string, string> = {
    sillas: 'Sillas',
    escritorios: 'Escritorios',
    accesorios: 'Accesorios',
    ambiente: 'Ambiente',
    'audio-video': 'Audio y Video',
  };

  interface Article {
    titulo: string;
    descripcion: string;
    slug: string;
    categoria: string;
    tipo: string;
    imagen: string | null;
    tags: string[];
    contenido: string;
  }

  let allArticles: Article[] = [];

  const input = document.getElementById('search-input') as HTMLInputElement;
  const meta = document.getElementById('search-meta')!;
  const loadingState = document.getElementById('loading-state')!;
  const emptyState = document.getElementById('empty-state')!;
  const noResultsState = document.getElementById('no-results-state')!;
  const resultsGrid = document.getElementById('results-grid')!;

  function normalize(str: string): string {
    return str
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function highlight(text: string, query: string): string {
    if (!query) return escapeHtml(text);
    const normText = normalize(text);
    const normQuery = normalize(query);
    const idx = normText.indexOf(normQuery);
    if (idx === -1) return escapeHtml(text);
    return (
      escapeHtml(text.slice(0, idx)) +
      '<mark>' +
      escapeHtml(text.slice(idx, idx + query.length)) +
      '</mark>' +
      escapeHtml(text.slice(idx + query.length))
    );
  }

  function getExcerpt(contenido: string, query: string, maxLen = 150): string {
    const norm = normalize(contenido);
    const normQ = normalize(query);
    const idx = norm.indexOf(normQ);
    if (idx === -1) return escapeHtml(contenido.slice(0, maxLen)) + '...';
    const start = Math.max(0, idx - 60);
    const end = Math.min(contenido.length, idx + query.length + 90);
    const prefix = start > 0 ? '...' : '';
    const suffix = end < contenido.length ? '...' : '';
    return highlight(prefix + contenido.slice(start, end) + suffix, query);
  }

  function renderCard(article: Article, query: string): string {
    const url = article.tipo === 'informativo'
      ? `/guias/${encodeURI(article.slug)}/`
      : `/${encodeURI(article.categoria)}/${encodeURI(article.slug)}/`;
    const catNombre = article.tipo === 'informativo'
      ? 'Guías'
      : (CATEGORIA_NOMBRES[article.categoria] || escapeHtml(article.categoria));
    const normQ = normalize(query);

    const inTitle = normalize(article.titulo).includes(normQ);
    const inDesc = normalize(article.descripcion).includes(normQ);
    const inTags = article.tags.some(t => normalize(t).includes(normQ));
    const showExcerpt = !inTitle && !inDesc && !inTags && article.contenido;

    const tituloHtml = highlight(article.titulo, query);
    const bodyHtml = showExcerpt
      ? getExcerpt(article.contenido, query)
      : highlight(article.descripcion, query);

    const imgHtml = article.imagen
      ? `<a href="${url}" class="article-card-image" aria-hidden="true" tabindex="-1">
           <img src="${escapeHtml(article.imagen)}" alt="" loading="lazy" />
         </a>`
      : '';

    return `
      <article class="article-card">
        ${imgHtml}
        <div class="article-card-body">
          <div class="article-card-badges">
            <span class="article-card-category badge badge-${article.tipo === 'informativo' ? 'guias' : article.categoria}">${catNombre}</span>
          </div>
          <a href="${url}"><h3 class="article-card-title">${tituloHtml}</h3></a>
          <p class="article-card-excerpt">${bodyHtml}</p>
          <div class="article-card-meta">
            <a href="${url}" class="article-card-link">Leer más →</a>
          </div>
        </div>
      </article>
    `;
  }

  function search(query: string) {
    const q = query.trim();

    if (!q) {
      loadingState.style.display = 'none';
      emptyState.classList.remove('search-state--hidden');
      noResultsState.classList.add('search-state--hidden');
      resultsGrid.classList.add('search-results--hidden');
      meta.classList.add('search-meta--hidden');
      return;
    }

    const normQ = normalize(q);
    const results = allArticles.filter(a =>
      normalize(a.titulo).includes(normQ) ||
      normalize(a.descripcion).includes(normQ) ||
      normalize(a.contenido).includes(normQ) ||
      a.tags.some(t => normalize(t).includes(normQ))
    );

    // Title matches first
    results.sort((a, b) => {
      const aT = normalize(a.titulo).includes(normQ) ? 0 : 1;
      const bT = normalize(b.titulo).includes(normQ) ? 0 : 1;
      return aT - bT;
    });

    loadingState.style.display = 'none';
    emptyState.classList.add('search-state--hidden');

    if (results.length === 0) {
      noResultsState.classList.remove('search-state--hidden');
      resultsGrid.classList.add('search-results--hidden');
      meta.classList.add('search-meta--hidden');
    } else {
      noResultsState.classList.add('search-state--hidden');
      resultsGrid.innerHTML = results.map(a => renderCard(a, q)).join('');
      resultsGrid.classList.remove('search-results--hidden');
      meta.textContent = `${results.length} ${results.length === 1 ? 'resultado' : 'resultados'} para "${q}"`;
      meta.classList.remove('search-meta--hidden');
    }
  }

  const urlQuery = new URLSearchParams(window.location.search).get('q');
  if (urlQuery) input.value = urlQuery;

  fetch('/buscar.json')
    .then(r => r.json())
    .then((data: Article[]) => {
      allArticles = data;
      loadingState.style.display = 'none';
      emptyState.classList.remove('search-state--hidden');
      if (input.value.trim()) search(input.value);
    })
    .catch(() => {
      loadingState.innerHTML = '<p class="search-error" role="alert">Error cargando el índice. Recarga la página.</p>';
    });

  let debounceTimer: ReturnType<typeof setTimeout>;
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => search(input.value), 200);
  });

  if (new URLSearchParams(window.location.search).get('q')) input.focus();
</script>
