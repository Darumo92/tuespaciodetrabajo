---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import CategoryIcon from '@/components/CategoryIcon.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos');

const destacados = articulos
  .filter(a => a.data.destacado)
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());

const recientes = articulos
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
  .slice(0, 4);

const comparativas = articulos.filter(a => a.data.tipo !== 'informativo');
const totalProductos = comparativas.reduce((sum, a) => {
  const matches = a.body?.match(/nombre:\s*"/g);
  return sum + (matches ? matches.length : 0);
}, 0);

// Avoid showing duplicate sections: if all recientes are already in destacados, skip recientes
const destacadoSlugs = new Set(destacados.map(a => a.slug));
const recientesSinDuplicar = recientes.filter(a => !destacadoSlugs.has(a.slug));
const mostrarRecientes = recientesSinDuplicar.length > 0;

// Only show stats when numbers are meaningful
const mostrarStats = totalProductos >= 10 && comparativas.length >= 3;

const siteUrl = 'https://tuespaciodetrabajo.com';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Tu Espacio de Trabajo',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/favicon.svg`,
  },
  description: 'Guías de compra y comparativas de productos de home office y ergonomía para teletrabajadores',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'contacto@tuespaciodetrabajo.com',
    contactType: 'customer service',
    availableLanguage: 'es',
  },
  foundingDate: '2026',
  areaServed: {
    '@type': 'Country',
    name: 'ES',
  },
  availableLanguage: 'es',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Últimos análisis de productos de home office',
  numberOfItems: recientes.length,
  itemListElement: recientes.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}/${a.data.tipo === 'informativo' ? 'guias' : a.data.categoria}/${a.slug}`,
    name: a.data.titulo,
  })),
};

// Seasonal content for home office
const now = new Date();
const month = now.getMonth() + 1; // 1-12

type SeasonalConfig = { tags: string[]; titulo: string; icono: string; color: string };
const seasonalMap: SeasonalConfig[] = [];

// Jan-Feb: New year resolutions + back to remote work
if (month >= 1 && month <= 2) {
  seasonalMap.push({ tags: ['propositos', 'renovar', 'setup'], titulo: 'Propósitos: renueva tu espacio', icono: '🎯', color: '#2563eb' });
  seasonalMap.push({ tags: ['teletrabajo', 'home office', 'vuelta'], titulo: 'Vuelta al trabajo remoto', icono: '💻', color: '#047857' });
}
// Mar-May: Spring refresh
if (month >= 3 && month <= 5) {
  seasonalMap.push({ tags: ['renovar', 'setup', 'primavera', 'organizacion'], titulo: 'Primavera: hora de renovar tu setup', icono: '🌱', color: '#047857' });
}
// Jun-Aug: Summer heat
if (month >= 6 && month <= 8) {
  seasonalMap.push({ tags: ['calor', 'verano', 'ventilacion', 'climatizacion'], titulo: 'Verano: combate el calor en tu oficina', icono: '☀️', color: '#d97706' });
}
// Sep-Nov: Back to routine + Black Friday
if (month >= 9 && month <= 11) {
  seasonalMap.push({ tags: ['vuelta', 'rutina', 'productividad', 'organizacion'], titulo: 'Vuelta a la rutina', icono: '📋', color: '#7c3aed' });
  seasonalMap.push({ tags: ['black friday', 'ofertas', 'descuentos'], titulo: 'Black Friday se acerca', icono: '🏷️', color: '#dc2626' });
}
// Dec: Gifts
if (month === 12) {
  seasonalMap.push({ tags: ['regalo', 'navidad', 'teletrabajador'], titulo: 'Regalos para teletrabajadores', icono: '🎁', color: '#dc2626' });
}

// Find matching seasonal articles
const seasonalArticles: { articulo: typeof articulos[0]; config: SeasonalConfig }[] = [];
for (const config of seasonalMap) {
  const match = articulos.find(a =>
    a.data.tags?.some(t => config.tags.some(st => t.toLowerCase().includes(st)))
  );
  if (match && !seasonalArticles.some(s => s.articulo.slug === match.slug)) {
    seasonalArticles.push({ articulo: match, config });
  }
}

const categorias = [
  {
    slug: 'sillas',
    nombre: 'Sillas',
    descripcion: 'Sillas ergonómicas, gaming, de oficina y económicas',
    count: articulos.filter(a => a.data.categoria === 'sillas').length,
  },
  {
    slug: 'escritorios',
    nombre: 'Escritorios',
    descripcion: 'Standing desks, escritorios regulares, esquineros y para espacios pequeños',
    count: articulos.filter(a => a.data.categoria === 'escritorios').length,
  },
  {
    slug: 'accesorios',
    nombre: 'Accesorios',
    descripcion: 'Teclados, ratones, soportes de monitor, reposamuñecas y más',
    count: articulos.filter(a => a.data.categoria === 'accesorios').length,
  },
  {
    slug: 'ambiente',
    nombre: 'Ambiente',
    descripcion: 'Iluminación, organización de cables, control de ruido y decoración',
    count: articulos.filter(a => a.data.categoria === 'ambiente').length,
  },
  {
    slug: 'audio-video',
    nombre: 'Audio y Video',
    descripcion: 'Auriculares, micrófonos, webcams y monitores para videollamadas',
    count: articulos.filter(a => a.data.categoria === 'audio-video').length,
  },
  {
    slug: 'guias',
    nombre: 'Guias',
    descripcion: 'Consejos de ergonomía, productividad y organización del home office',
    count: articulos.filter(a => a.data.tipo === 'informativo').length,
  },
];
---

<Base
  title="Tu Espacio de Trabajo · Guías y comparativas de home office"
  description="Análisis honestos y comparativas de sillas ergonómicas, escritorios, accesorios y equipamiento para tu home office. Todo lo que necesitas para teletrabajar mejor."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">
        Tu espacio de trabajo perfecto,<br />
        <span>sin perder tiempo buscando</span>
      </h1>
      <p class="hero-subtitle">
        Analizamos sillas, escritorios y accesorios en Amazon para que tú solo tengas que elegir.
      </p>
      {mostrarStats && (
        <div class="hero-stats">
          <div class="hero-stat">
            <strong>{totalProductos}+</strong>
            <span>productos</span>
          </div>
          <div class="hero-stat">
            <strong>{comparativas.length}</strong>
            <span>comparativas</span>
          </div>
          <div class="hero-stat">
            <strong>100%</strong>
            <span>independiente</span>
          </div>
        </div>
      )}
      <div class="hero-cta">
        {categorias.map(cat => (
          <a href={`/${cat.slug}/`} class="hero-cat-pill">
            <CategoryIcon categoria={cat.slug} size={16} /> {cat.nombre}
          </a>
        ))}
      </div>
      <p class="hero-meta">
        Precios actualizados en {new Date().toLocaleDateString('es-ES', { month: 'long', year: 'numeric' })} · Comparados en Amazon.es
      </p>
    </div>
  </section>

  <!-- Seasonal Banner -->
  {seasonalArticles.length > 0 && (
    <section class="seasonal-banner">
      <div class="container">
        <div class="seasonal-items">
          {seasonalArticles.slice(0, 2).map(({ articulo: sa, config }) => {
            const saUrl = `/${sa.data.tipo === 'informativo' ? 'guias' : sa.data.categoria}/${sa.slug}/`;
            return (
              <a href={saUrl} class="seasonal-item" style={`--seasonal-color: ${config.color}`}>
                <span class="seasonal-icon">{config.icono}</span>
                <div class="seasonal-text">
                  <strong>{config.titulo}</strong>
                  <span>{sa.data.titulo}</span>
                </div>
                <span class="seasonal-arrow">→</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Trust / Social proof — above the fold for E-E-A-T -->
  <section class="trust-section">
    <div class="container">
      <div class="trust-grid reveal-group">
        <div class="trust-card">
          <span class="trust-card-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></span>
          <div>
            <strong>Análisis independientes</strong>
            <p>Probamos y comparamos productos reales. Sin reseñas patrocinadas.</p>
          </div>
        </div>
        <div class="trust-card">
          <span class="trust-card-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg></span>
          <div>
            <strong>Precios actualizados</strong>
            <p>Comparamos precios en Amazon.es para mostrarte las mejores opciones.</p>
          </div>
        </div>
        <div class="trust-card">
          <span class="trust-card-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="21 3 21 9 15 9"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L21 9"/></svg></span>
          <div>
            <strong>Actualizado regularmente</strong>
            <p>Revisamos precios y disponibilidad para que la info sea fiable.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categorias -->
  <section class="section" style="background: var(--color-bg-muted); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <h2 class="section-title">Explora por categoría</h2>
      <p class="section-subtitle">Encuentra exactamente lo que necesitas para tu home office</p>
      <div class="categories-grid reveal-group">
        {categorias.map(cat => (
          <a href={`/${cat.slug}/`} class="category-card">
            <span class="category-icon" aria-hidden="true"><CategoryIcon categoria={cat.slug} size={24} /></span>
            <div class="category-info">
              <h3>{cat.nombre}</h3>
              <p>{cat.descripcion}</p>
              {cat.count > 0 ? (
                <p style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--color-primary); font-weight: 600;">
                  {cat.count} {cat.count === 1 ? 'artículo' : 'artículos'}
                </p>
              ) : (
                <p style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--color-text-light); font-weight: 500;">
                  Próximamente
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Destacados -->
  {destacados.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title reveal">Destacados</h2>
        <p class="section-subtitle reveal">Nuestros análisis más completos y populares</p>
        <div class="articles-grid reveal-group">
          {destacados.map(articulo => (
            <ArticleCard articulo={articulo} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Articulos recientes (only if they add new content beyond destacados) -->
  {mostrarRecientes && (
    <section class="section">
      <div class="container">
        <h2 class="section-title reveal">Últimos análisis</h2>
        <p class="section-subtitle reveal">Los artículos más recientes del blog</p>
        <div class="articles-grid reveal-group">
          {recientesSinDuplicar.map(articulo => (
            <ArticleCard articulo={articulo} />
          ))}
        </div>
      </div>
    </section>
  )}

</Base>
