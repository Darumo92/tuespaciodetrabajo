---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import CategoryIcon from '@/components/CategoryIcon.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('articulos');

const destacados = articulos
  .filter(a => a.data.destacado)
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());

const recientes = articulos
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
  .slice(0, 4);

// Avoid showing duplicate sections: if all recientes are already in destacados, skip recientes
const destacadoSlugs = new Set(destacados.map(a => a.slug));
const recientesSinDuplicar = recientes.filter(a => !destacadoSlugs.has(a.slug));
const mostrarRecientes = recientesSinDuplicar.length > 0;

const siteUrl = 'https://tuespaciodetrabajo.com';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Tu Espacio de Trabajo',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/favicon.svg`,
    width: 512,
    height: 512,
  },
  description: 'Guías de compra y comparativas de productos de home office y ergonomía para teletrabajadores',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'contacto@tuespaciodetrabajo.com',
    contactType: 'customer service',
    availableLanguage: 'es',
  },
  foundingDate: '2026',
  areaServed: {
    '@type': 'Country',
    name: 'ES',
  },
  availableLanguage: 'es',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Últimos análisis de productos de home office',
  numberOfItems: recientes.length,
  itemListElement: recientes.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${siteUrl}/${a.data.tipo === 'informativo' ? 'guias' : a.data.categoria}/${a.slug}/`,
    name: a.data.titulo,
  })),
};

const catColors: Record<string, string> = {
  sillas: '#2563eb',
  escritorios: '#f59e0b',
  accesorios: '#10b981',
  ambiente: '#ec4899',
  'audio-video': '#8b5cf6',
  guias: '#f43f5e',
};

const categorias = [
  {
    slug: 'sillas',
    nombre: 'Sillas',
    descripcion: 'Sillas ergonómicas, gaming, de oficina y económicas',
    count: articulos.filter(a => a.data.categoria === 'sillas').length,
  },
  {
    slug: 'escritorios',
    nombre: 'Escritorios',
    descripcion: 'Standing desks, escritorios regulares, esquineros y para espacios pequeños',
    count: articulos.filter(a => a.data.categoria === 'escritorios').length,
  },
  {
    slug: 'accesorios',
    nombre: 'Accesorios',
    descripcion: 'Teclados, ratones, soportes de monitor, reposamuñecas y más',
    count: articulos.filter(a => a.data.categoria === 'accesorios').length,
  },
  {
    slug: 'ambiente',
    nombre: 'Ambiente',
    descripcion: 'Iluminación, organización de cables, control de ruido y decoración',
    count: articulos.filter(a => a.data.categoria === 'ambiente').length,
  },
  {
    slug: 'audio-video',
    nombre: 'Audio y Video',
    descripcion: 'Auriculares, micrófonos, webcams y monitores para videollamadas',
    count: articulos.filter(a => a.data.categoria === 'audio-video').length,
  },
  {
    slug: 'guias',
    nombre: 'Guias',
    descripcion: 'Consejos de ergonomía, productividad y organización del home office',
    count: articulos.filter(a => a.data.tipo === 'informativo').length,
  },
];
---

<Base
  title="Tu Espacio de Trabajo · Guías y comparativas de home office"
  description="Comparativas de sillas ergonómicas, escritorios y accesorios para tu home office. Todo lo que necesitas para teletrabajar mejor."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="hero-label">
        <span class="hero-label-dot" aria-hidden="true"></span>
        Guías y comparativas {new Date().getFullYear()}
      </p>
      <h1 class="hero-title">
        Tu espacio de trabajo, analizado al detalle
      </h1>
      <p class="hero-subtitle">
        Análisis independientes de sillas, escritorios y accesorios para teletrabajar desde casa con ergonomía real.
      </p>
      <div class="hero-cta">
        <a href="/articulos/" class="hero-cta-btn hero-cta-primary">
          Ver comparativas
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/guias/" class="hero-cta-btn hero-cta-secondary">Leer guías</a>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <div class="trust-strip">
    <div class="container">
      <div class="trust-strip-inner">
        <div class="trust-strip-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <span>Análisis independientes</span>
        </div>
        <div class="trust-strip-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>
          <span>Precios actualizados</span>
        </div>
        <div class="trust-strip-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="21 3 21 9 15 9"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L21 9"/></svg>
          <span>Actualizado regularmente</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Categorias -->
  <section class="section section-categories">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Explora por categoría</h2>
        <p class="section-subtitle">Encuentra exactamente lo que necesitas para tu home office</p>
      </div>
      <div class="categories-grid reveal-group">
        {categorias.map(cat => (
          <a href={`/${cat.slug}/`} class="category-card" style={`--cat-color: ${catColors[cat.slug] || '#2563eb'}`}>
            <div class="category-card-glow" aria-hidden="true"></div>
            <span class="category-icon" aria-hidden="true"><CategoryIcon categoria={cat.slug} size={28} /></span>
            <h3 class="category-card-name">{cat.nombre}</h3>
            <p class="category-card-desc">{cat.descripcion}</p>
            {cat.count > 0 ? (
              <span class="category-card-count">{cat.count} {cat.count === 1 ? 'artículo' : 'artículos'} →</span>
            ) : (
              <span class="category-card-count category-card-count--empty">Próximamente</span>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Destacados -->
  {destacados.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="section-header">
          <span class="section-eyebrow">Selección del editor</span>
          <h2 class="section-title reveal">Destacados</h2>
          <p class="section-subtitle reveal">Nuestros análisis más completos y populares</p>
        </div>
        <div class="articles-grid reveal-group">
          {destacados.map(articulo => (
            <ArticleCard articulo={articulo} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Articulos recientes (only if they add new content beyond destacados) -->
  {mostrarRecientes && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="section-eyebrow">Recién publicado</span>
          <h2 class="section-title reveal">Últimos análisis</h2>
          <p class="section-subtitle reveal">Los artículos más recientes del blog</p>
        </div>
        <div class="articles-grid reveal-group">
          {recientesSinDuplicar.map(articulo => (
            <ArticleCard articulo={articulo} />
          ))}
        </div>
      </div>
    </section>
  )}

</Base>
