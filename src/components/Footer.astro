---
import LogoIcon from './LogoIcon.astro';

const categorias = [
  { href: '/sillas/', label: 'Sillas' },
  { href: '/escritorios/', label: 'Escritorios' },
  { href: '/accesorios/', label: 'Accesorios' },
  { href: '/ambiente/', label: 'Ambiente' },
  { href: '/audio-video/', label: 'Audio y Video' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo footer-logo">
          <LogoIcon size={28} />
          Tu Espacio de <span class="footer-logo-accent">Trabajo</span>
        </a>
        <p class="footer-brand-text">
          Guias de compra y comparativas de productos para tu home office.
          Análisis honestos para ayudarte a crear el espacio de trabajo perfecto.
        </p>
      </div>

      <nav class="footer-col" aria-label="Categorias">
        <h4 class="footer-heading">Categorias</h4>
        <ul class="footer-links" role="list">
          {categorias.map(c => (
            <li><a href={c.href}>{c.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav class="footer-col" aria-label="Explorar">
        <h4 class="footer-heading">Explorar</h4>
        <ul class="footer-links" role="list">
          <li><a href="/guias/">Guías</a></li>
          <li><a href="/articulos/">Todos los artículos</a></li>
          <li><a href="/sobre-mi/">Sobre mí</a></li>
        </ul>
      </nav>

      <nav class="footer-col" aria-label="Informacion legal">
        <h4 class="footer-heading">Legal</h4>
        <ul class="footer-links" role="list">
          <li><a href="/politica-privacidad/">Privacidad</a></li>
          <li><a href="/aviso-legal/">Aviso legal</a></li>
          <li><a href="/cookies/">Cookies</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer-affiliate-notice">
      ⚠️ <strong>Aviso de afiliados:</strong> tuespaciodetrabajo.com participa en el
      Programa de Afiliados de Amazon EU. Cuando
      compras a través de nuestros enlaces podemos recibir una comisión sin coste
      adicional para ti. Esto nos ayuda a mantener el sitio gratuito.
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} tuespaciodetrabajo.com &middot; Todos los derechos reservados</p>
    </div>
  </div>
</footer>
<a href="#" class="footer-back-top" aria-label="Volver arriba">↑</a>

