---
interface Props {
  size?: number;
}
const { size = 28 } = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" width={size} height={size} aria-hidden="true" class="logo-svg">
  <!-- Simple desk with monitor icon -->
  <rect x="18" y="8" width="28" height="22" rx="2" stroke="currentColor" stroke-width="3" fill="none"/>
  <line x1="32" y1="30" x2="32" y2="38" stroke="currentColor" stroke-width="3"/>
  <line x1="24" y1="38" x2="40" y2="38" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
  <line x1="8" y1="46" x2="56" y2="46" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
  <line x1="12" y1="46" x2="12" y2="56" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
  <line x1="52" y1="46" x2="52" y2="56" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
</svg>
