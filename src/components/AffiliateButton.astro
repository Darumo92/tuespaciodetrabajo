---
import StoreIcon from './StoreIcon.astro';

interface Props {
  href: string;
  tienda?: 'amazon' | 'default';
  texto?: string;
}

const { href, tienda = 'default', texto } = Astro.props;

const tiendaInfo: Record<string, { label: string }> = {
  amazon: { label: 'Ver en Amazon' },
  default: { label: 'Ver oferta' },
};

const info = tiendaInfo[tienda];
const label = texto || info.label;

const normalizedHref = tienda === 'amazon' && href.startsWith('/dp/')
  ? `https://www.amazon.es${href}`
  : href;

const finalHref = tienda === 'amazon' && !normalizedHref.includes('tag=')
  ? `${normalizedHref}${normalizedHref.includes('?') ? '&' : '?'}tag=tuespaciodet-21`
  : normalizedHref;
---

<a
  href={finalHref}
  class={`affiliate-button ${tienda !== 'default' ? tienda : ''}`}
  target="_blank"
  rel="nofollow noopener noreferrer sponsored"
>
  <StoreIcon tienda={tienda} size={15} />
  {label}
  <span class="sr-only">(se abre en nueva pestaña)</span>
</a>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
